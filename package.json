        "bundle": "npm run build && npx @anthropic-ai/mcpb pack . masv-mcp-server.mcpb"
    },
    "files": [
        "build"
    ],
    "dependencies": {
        "@modelcontextprotocol/sdk": "1.27.1",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@anthropic-ai/mcpb": "2.1.2",
        "@types/node": "25.3.0",
        "typescript": "5.9.3"
    }
}