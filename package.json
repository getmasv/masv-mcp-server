{
    "name": "masv-mcp-server",
    "version": "0.0.3",
    "description": "MASV MCP server provides LLMs with tools to control MASV API",
    "keywords": [
        "masv",
        "massive",
        "file",
        "transfer",
        "mcp",
        "llm",
        "ai"
    ],
    "license": "MIT",
    "author": "Vladyslav Ilchenko",
    "type": "module",
    "bin": {
        "masv-mcp-server": "./build/index.js"
    },
    "mcpName": "",
    "scripts": {
        "build": "tsc && chmod 755 build/index.js",
        "test": "echo \"Error: no test specified\" && exit 1",
